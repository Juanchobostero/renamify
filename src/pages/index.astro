---
// renamr — renombrador masivo de imágenes
// Astro + Vanilla JS + JSZip · todo client-side
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Renamify — renombrador masivo de imágenes</title>
  <meta name="description" content="Subí hasta 400 imágenes, definí un nombre base y descargalas todas renombradas en un .zip. Sin servidores, todo en tu navegador." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=DM+Mono:ital,wght@0,400;0,500;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
</head>

<body>
  <!-- Fondo y ambiente visual -->
  <div class="noise" aria-hidden="true"></div>
  <div class="orb orb1" aria-hidden="true"></div>
  <div class="orb orb2" aria-hidden="true"></div>

  <div class="app">

    <!-- Header -->
    <header>
      <div class="logo-row">
        <div class="logo-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2.2" stroke="currentColor">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="17 8 12 3 7 8"/>
            <line x1="12" y1="3" x2="12" y2="15"/>
          </svg>
        </div>
        <div>
          <div class="brand">Renamify</div>
          <div class="tagline">renombrador masivo de imágenes</div>
        </div>
      </div>
      <div style="display:flex; align-items:center; gap:12px;">
        <button class="theme-toggle" id="themeToggle" title="Cambiar tema" type="button">
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
        <span class="badge-free">100% gratis · sin registro</span>
      </div>
    </header>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-left">
        <div class="slogan-badge">
          <span class="slogan-dot" aria-hidden="true"></span>
          Renombrá tus imágenes en segundos
        </div>
        <h1>Renombrado<br />masivo, <em>sin vueltas.</em></h1>
        <p>
          Subí hasta 400 imágenes, definí un nombre base y descargalas todas
          renombradas en un <code>.zip</code>. Sin servidores, todo en tu navegador.
        </p>
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-n">400</span>
            <span class="stat-l">imágenes por vez</span>
          </div>
          <div class="stat-divider" aria-hidden="true"></div>
          <div class="stat">
            <span class="stat-n">0</span>
            <span class="stat-l">datos enviados</span>
          </div>
          <div class="stat-divider" aria-hidden="true"></div>
          <div class="stat">
            <span class="stat-n">gratis</span>
            <span class="stat-l">para siempre</span>
          </div>
        </div>
      </div>

      <!-- Mockup visual -->
      <div class="hero-right" aria-hidden="true">
        <div class="mockup-window">
          <div class="mockup-bar">
            <span class="mockup-dot md-red"></span>
            <span class="mockup-dot md-yellow"></span>
            <span class="mockup-dot md-green"></span>
            <span class="mockup-title">Renamify</span>
          </div>
          <div class="mockup-body">
            <div class="mockup-label">● IMÁGENES</div>
            <div class="mockup-cards">
              <div class="mockup-card">
                <div class="mockup-thumb" style="background:#2a1e1e;">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4a3030" stroke-width="1.2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                </div>
                <div class="mockup-card-badge">001</div>
                <div class="mockup-card-body">
                  <div class="mockup-old">IMG_4521.jpg</div>
                  <div class="mockup-new">producto_001.jpg</div>
                </div>
              </div>
              <div class="mockup-card">
                <div class="mockup-thumb" style="background:#1e2a1e;">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#304a30" stroke-width="1.2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                </div>
                <div class="mockup-card-badge">002</div>
                <div class="mockup-card-body">
                  <div class="mockup-old">DSC_0032.jpg</div>
                  <div class="mockup-new">producto_002.jpg</div>
                </div>
              </div>
              <div class="mockup-card">
                <div class="mockup-thumb" style="background:#1e1e2a;">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#30304a" stroke-width="1.2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                </div>
                <div class="mockup-card-badge">003</div>
                <div class="mockup-card-body">
                  <div class="mockup-old">foto_camara.png</div>
                  <div class="mockup-new">producto_003.png</div>
                </div>
              </div>
            </div>
            <div class="mockup-seed-row">
              <div class="mockup-input-wrap">
                <div class="mockup-input-label">Nombre semilla</div>
                <div class="mockup-input">producto</div>
              </div>
              <div class="mockup-input-wrap mockup-input-sm">
                <div class="mockup-input-label">Dígitos</div>
                <div class="mockup-input">3</div>
              </div>
            </div>
            <div class="mockup-preview-bar">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#c8f03c" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              <span>producto_001.jpg</span>
            </div>
            <div class="mockup-btn">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#0b0d0f" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Descargar .zip
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Steps -->
    <div class="steps-bar" id="stepsBar">
      <div class="step active" data-step="1">
        <div class="step-n">1</div>
        <span>Subir imágenes</span>
      </div>
      <span class="step-arrow">›</span>
      <div class="step" data-step="2">
        <div class="step-n">2</div>
        <span>Configurar nombre</span>
      </div>
      <span class="step-arrow">›</span>
      <div class="step" data-step="3">
        <div class="step-n">3</div>
        <span>Descargar .zip</span>
      </div>
    </div>

    <!-- Card: Drop zone -->
    <div class="card" id="cardDrop">
      <div class="card-header">
        <div class="card-label">Imágenes</div>
        <span class="file-counter" id="fileCounter" style="display:none"></span>
      </div>

      <!-- Drop zone -->
      <div
        class="dropzone"
        id="dropzone"
        role="button"
        tabindex="0"
        aria-label="Zona para subir imágenes"
      >
        <div class="drop-icon-wrap" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="17 8 12 3 7 8"/>
            <line x1="12" y1="3" x2="12" y2="15"/>
          </svg>
        </div>
        <div class="drop-title">Arrastrá las imágenes acá</div>
        <div class="drop-sub">o hacé clic para explorar archivos</div>
        <div class="drop-pills">
          <span class="pill">JPG</span>
          <span class="pill">PNG</span>
          <span class="pill">WEBP</span>
          <span class="pill">GIF</span>
          <span class="pill limit">máx. 400 imágenes</span>
        </div>
      </div>

      <!-- Input file oculto -->
      <input
        type="file"
        id="fileInput"
        multiple
        accept="image/jpeg,image/png,image/webp,image/gif"
        style="display:none"
        aria-hidden="true"
      />

      <!-- Mensaje de error -->
      <div class="error-msg" id="errorMsg" role="alert" style="display:none"></div>
    </div>

    <!-- Card: Nombre base (se muestra cuando hay archivos) -->
    <div class="card" id="cardSeed" style="display:none">
      <div class="card-header">
        <div class="card-label">Nombre base</div>
      </div>
      <div class="seed-grid">
        <div class="field">
          <label for="seed">Nombre semilla</label>
          <input
            type="text"
            id="seed"
            value="producto"
            placeholder="ej: producto, item, foto..."
            maxlength="80"
          />
          <p class="field-hint" id="seedHint">Caracteres inválidos: / \ : * ? " &lt; &gt; |</p>
          <div class="seed-history" id="seedHistory" style="display:none">
            <span class="seed-history-label">Recientes:</span>
          </div>
        </div>
        <div class="field">
          <label for="startNum">Desde número</label>
          <input type="number" id="startNum" value="1" min="0" max="9999" />
        </div>
        <div class="field">
          <label for="digits">Dígitos</label>
          <input type="number" id="digits" value="3" min="1" max="5" />
        </div>
      </div>
      <div class="preview-result">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <span class="preview-label">Vista previa del nombre generado:</span>
        <span class="preview-val" id="previewVal">producto_001.jpg</span>
      </div>
    </div>

    <!-- Card: Vista previa de archivos (se muestra cuando hay archivos) -->
    <div class="card" id="cardPreview" style="display:none">
      <div class="card-header">
        <div class="card-label">Vista previa de archivos</div>
        <span class="muted-sm" id="previewMeta"></span>
      </div>
      <div class="grid-preview" id="previewGrid"></div>
    </div>

    <!-- Action bar -->
    <div class="action-bar" id="actionBar" style="display:none">
      <div class="file-count">
        <span class="count-bubble" id="countBubble">0 archivos</span>
        <span class="count-label">listos para descargar</span>
      </div>
      <div class="actions">
        <button class="btn-clear" id="btnClear" type="button">Limpiar todo</button>
        <div class="btn-download-wrap">
          <button class="btn-download" id="btnDownload" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" aria-hidden="true">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            <span id="btnLabel">Descargar .zip</span>
          </button>
          <button class="btn-download-opts" id="btnOpts" type="button" title="Opciones de exportación">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>
          <div class="download-menu" id="downloadMenu">
            <button class="download-menu-item" id="btnWithCsv" type="button">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="8" y1="13" x2="16" y2="13"/>
                <line x1="8" y1="17" x2="16" y2="17"/>
              </svg>
              Descargar .zip + mapeo.csv
            </button>
            <button class="download-menu-item" id="btnWithJson" type="button">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="8" y1="13" x2="16" y2="13"/>
                <line x1="8" y1="17" x2="16" y2="17"/>
              </svg>
              Descargar .zip + mapeo.json
            </button>
          </div>
        </div>
      </div>

    <!-- Nota de privacidad -->
    <div class="privacy-note">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      Tus imágenes <strong>nunca salen de tu navegador</strong>. No hay servidores, no hay carga de archivos. Todo es 100% local y privado.
    </div>

    <!-- Toast -->
  <div class="toast" id="toast">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <polyline points="20 6 9 17 4 12"/>
    </svg>
    <span id="toastMsg">¡Listo!</span>
  </div>
  </div><!-- /app -->
</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:       #0b0d0f;
    --surface:  #13161a;
    --surface2: #1c2026;
    --border:   rgba(255,255,255,0.07);
    --border2:  rgba(255,255,255,0.13);
    --accent:   #c8f03c;
    --accent2:  #9bbc28;
    --text:     #f0f2f0;
    --muted:    #7a8080;
    --muted2:   #4a5050;
    --danger:   #ff6b6b;
    --mono:     'DM Mono', monospace;
    --sans:     'DM Sans', sans-serif;
    --display: 'Space Grotesk', sans-serif;
    --radius:   14px;
    --radius-sm: 10px;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    min-height: 100vh;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Fondo ── */
  .noise {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    opacity: 0.55;
  }
  .orb {
    position: fixed; pointer-events: none; z-index: 0;
    border-radius: 50%; filter: blur(80px);
  }
  .orb1 { width: 500px; height: 500px; top: -120px; left: -100px; background: radial-gradient(circle, rgba(200,240,60,0.11) 0%, transparent 70%); }
  .orb2 { width: 350px; height: 350px; bottom: 60px;  right: -80px;  background: radial-gradient(circle, rgba(200,240,60,0.07) 0%, transparent 70%); }

  /* ── Layout ── */
  .app {
    position: relative; z-index: 1;
    max-width: 840px;
    margin: 0 auto;
    padding: 0 1.5rem 5rem;
  }

  /* ── Header ── */
  header {
    padding: 2.5rem 0 2rem;
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 0.5px solid var(--border);
    margin-bottom: 2.5rem;
    animation: fadeUp 0.5s ease both;
  }
  .logo-row { display: flex; align-items: center; gap: 12px; }
  .logo-icon {
    width: 38px; height: 38px; border-radius: 11px;
    background: var(--accent);
    display: flex; align-items: center; justify-content: center;
    color: var(--bg);
    flex-shrink: 0;
  }
  .logo-icon svg { width: 18px; height: 18px; }
  .brand    { font-family: var(--display); font-size: 19px; font-weight: 700; letter-spacing: -0.02em; color: var(--text); }
  .tagline  { font-size: 12px; color: var(--muted); margin-top: 2px; font-weight: 300; }
  .badge-free {
    font-size: 11px; font-family: var(--mono);
    color: var(--accent); border: 0.5px solid rgba(200,240,60,0.3);
    padding: 4px 12px; border-radius: 20px;
    background: rgba(200,240,60,0.06);
    white-space: nowrap;
  }

  /* ── Hero ── */
.hero {
  margin-bottom: 2.5rem;
  animation: fadeUp 0.5s 0.08s ease both;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
}
.hero-left { display: flex; flex-direction: column; }
.hero-right {
  display: flex; justify-content: flex-end; align-items: center;
}

.mockup-window {
  width: 100%; max-width: 340px;
  background: #0f1215;
  border: 0.5px solid rgba(255,255,255,0.12);
  border-radius: 14px; overflow: hidden;
  transform: rotate(2deg);
  box-shadow: 0 24px 60px rgba(0,0,0,0.5), 0 0 0 0.5px rgba(200,240,60,0.08);
  transition: transform 0.4s ease;
}
.mockup-window:hover { transform: rotate(0deg) scale(1.01); }

.mockup-bar {
  display: flex; align-items: center; gap: 6px;
  padding: 10px 14px;
  border-bottom: 0.5px solid rgba(255,255,255,0.07);
  background: #0b0d0f;
}
.mockup-dot { width: 10px; height: 10px; border-radius: 50%; }
.md-red    { background: #ff5f57; }
.md-yellow { background: #febc2e; }
.md-green  { background: #28c840; }
.mockup-title {
  font-family: var(--mono); font-size: 11px;
  color: rgba(255,255,255,0.3);
  margin-left: auto; margin-right: auto; padding-right: 26px;
  letter-spacing: 0.05em;
}

.mockup-body { padding: 14px; display: flex; flex-direction: column; gap: 10px; }
.mockup-label {
  font-family: var(--mono); font-size: 9px; font-weight: 500;
  color: rgba(255,255,255,0.3); text-transform: uppercase; letter-spacing: 0.1em;
}

.mockup-cards { display: grid; grid-template-columns: repeat(3,1fr); gap: 6px; }
.mockup-card {
  background: #1c2026; border: 0.5px solid rgba(255,255,255,0.07);
  border-radius: 8px; overflow: hidden; position: relative;
}
.mockup-thumb {
  width: 100%; height: 54px;
  display: flex; align-items: center; justify-content: center;
}
.mockup-card-badge {
  position: absolute; top: 4px; right: 4px;
  background: rgba(11,13,15,0.8);
  font-family: var(--mono); font-size: 8px; font-weight: 500;
  color: #c8f03c; padding: 1px 5px; border-radius: 10px;
  border: 0.5px solid rgba(255,255,255,0.1);
}
.mockup-card-body { padding: 5px 6px 6px; border-top: 0.5px solid rgba(255,255,255,0.06); }
.mockup-old {
  font-family: var(--mono); font-size: 7px; color: rgba(255,255,255,0.2);
  text-decoration: line-through; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.mockup-new {
  font-family: var(--mono); font-size: 8px; font-weight: 500;
  color: rgba(255,255,255,0.85);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2px;
}

.mockup-seed-row { display: flex; gap: 6px; }
.mockup-input-wrap { flex: 1; }
.mockup-input-wrap.mockup-input-sm { flex: 0 0 52px; }
.mockup-input-label { font-family: var(--mono); font-size: 8px; color: rgba(255,255,255,0.3); margin-bottom: 4px; }
.mockup-input {
  background: #1c2026; border: 0.5px solid rgba(255,255,255,0.1);
  border-radius: 6px; padding: 5px 8px;
  font-family: var(--mono); font-size: 10px; color: rgba(255,255,255,0.75);
}

.mockup-preview-bar {
  display: flex; align-items: center; gap: 6px;
  background: rgba(200,240,60,0.06); border: 0.5px solid rgba(200,240,60,0.18);
  border-radius: 6px; padding: 6px 10px;
  font-family: var(--mono); font-size: 10px; font-weight: 500; color: #c8f03c;
}

.mockup-btn {
  display: flex; align-items: center; justify-content: center; gap: 7px;
  background: #c8f03c; color: #0b0d0f;
  font-family: var(--display); font-size: 11px; font-weight: 700;
  border-radius: 7px; padding: 8px 0; cursor: default;
}

.slogan-badge {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: var(--mono); font-size: 12px; font-weight: 500;
  color: var(--accent);
  background: rgba(200,240,60,0.08);
  border: 0.5px solid rgba(200,240,60,0.25);
  padding: 6px 14px; border-radius: 30px;
  margin-bottom: 18px; letter-spacing: 0.01em;
}
.slogan-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--accent); flex-shrink: 0;
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
