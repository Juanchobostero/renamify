<script>
  import JSZip from 'jszip';

  // ── Estado ──────────────────────────────────────────────
  let files = [];          // File[] — archivos seleccionados
  const MAX = 400;

  // ── Referencias DOM ─────────────────────────────────────
  const dropzone    = document.getElementById('dropzone');
  const fileInput   = document.getElementById('fileInput');
  const previewGrid = document.getElementById('previewGrid');
  const previewMeta = document.getElementById('previewMeta');
  const previewVal  = document.getElementById('previewVal');
  const countBubble = document.getElementById('countBubble');
  const fileCounter = document.getElementById('fileCounter');
  const errorMsg    = document.getElementById('errorMsg');
  const cardSeed    = document.getElementById('cardSeed');
  const cardPreview = document.getElementById('cardPreview');
  const actionBar   = document.getElementById('actionBar');
  const btnDownload = document.getElementById('btnDownload');
  const btnLabel    = document.getElementById('btnLabel');
  const btnClear    = document.getElementById('btnClear');
  const seedInput   = document.getElementById('seed');
  const startInput  = document.getElementById('startNum');
  const digitsInput = document.getElementById('digits');
  const stepsBar    = document.getElementById('stepsBar');

  // ── Helpers ─────────────────────────────────────────────
  function pad(n, d) {
    const digits = Math.min(Math.max(parseInt(d) || 3, 1), 5);
    return String(Math.max(0, parseInt(n) || 0)).padStart(digits, '0');
  }

  function getExt(filename) {
    const parts = filename.split('.');
    return parts.length > 1 ? parts.pop().toLowerCase() : '';
  }

  function buildNewName(index) {
    const seed  = seedInput.value.trim() || 'imagen';
    const start = parseInt(startInput.value) || 1;
    const d     = digitsInput.value;
    const num   = pad(start + index, d);
    const ext   = getExt(files[index].name);
    return `${seed}_${num}${ext ? '.' + ext : ''}`;
  }

  function updatePreviewLabel() {
    const seed  = seedInput.value.trim() || 'imagen';
    const start = parseInt(startInput.value) || 1;
    const d     = digitsInput.value;
    const num   = pad(start, d);
    const ext   = files.length > 0 ? getExt(files[0].name) || 'jpg' : 'jpg';
    previewVal.textContent = `${seed}_${num}.${ext}`;
  }

  function showError(msg) {
    errorMsg.textContent = msg;
    errorMsg.style.display = 'block';
    setTimeout(() => { errorMsg.style.display = 'none'; }, 4000);
  }

  function showToast(msg) {
    const toast = document.getElementById('toast');
    const toastMsg = document.getElementById('toastMsg');
    toastMsg.textContent = msg;
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 3000);
  }

  function loadHistory() {
    const history = JSON.parse(localStorage.getItem('renamr_history') || '[]');
    const container = document.getElementById('seedHistory');
    container.innerHTML = '<span class="seed-history-label">Recientes:</span>';

    if (history.length === 0) {
      container.style.display = 'none';
      return;
    }

    container.style.display = 'flex';
    history.forEach(name => {
      const chip = document.createElement('button');
      chip.className = 'seed-chip';
      chip.textContent = name;
      chip.type = 'button';
      chip.addEventListener('click', () => {
        seedInput.value = name;
        updateGridNames();
      });
      container.appendChild(chip);
    });
  }

  function saveToHistory(name) {
    if (!name.trim()) return;
    let history = JSON.parse(localStorage.getItem('renamr_history') || '[]');
    history = [name, ...history.filter(n => n !== name)].slice(0, 5);
    localStorage.setItem('renamr_history', JSON.stringify(history));
    loadHistory();
  }

  function buildCsv() {
    const rows = ['nombre_original,nombre_nuevo'];
    files.forEach((f, i) => rows.push(`${f.name},${buildNewName(i)}`));
    return rows.join('\n');
  }

  function buildJsonMap() {
    return JSON.stringify(
      files.map((f, i) => ({ original: f.name, nuevo: buildNewName(i) })),
      null, 2
    );
  }

  async function downloadZipWith(extra) {
    if (files.length === 0) return;
    btnDownload.disabled = true;
    btnLabel.textContent = 'Generando .zip...';
    document.getElementById('downloadMenu').classList.remove('open');

    try {
      const zip = new JSZip();

      for (let i = 0; i < files.length; i++) {
        zip.file(buildNewName(i), files[i]);
        const pct = Math.round(((i + 1) / files.length) * 50);
        btnLabel.textContent = `Procesando ${i + 1}/${files.length} — ${pct}%`;
        if (i % 10 === 0) await new Promise(r => setTimeout(r, 0));
      }

      if (extra === 'csv')  zip.file('mapeo.csv',  buildCsv());
      if (extra === 'json') zip.file('mapeo.json', buildJsonMap());

      const blob = await zip.generateAsync(
        { type: 'blob', compression: 'STORE' },
        (meta) => { btnLabel.textContent = `Empaquetando — ${50 + Math.round(meta.percent / 2)}%`; }
      );

      const seedName = (seedInput.value.trim() || 'imagenes').replace(/\s+/g, '_');
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = `${seedName}_renombradas.zip`;
      a.click();
      URL.revokeObjectURL(a.href);

      saveToHistory(seedInput.value.trim() || 'imagen');
      updateSteps(3);
      showToast(`✓ ${files.length} ${files.length === 1 ? 'imagen descargada' : 'imágenes descargadas'}`);
      const delay = Math.min(Math.max(files.length * 50, 2000), 8000);
      setTimeout(clearAll, delay);

    } catch (err) {
      console.error(err);
      showError('Ocurrió un error al generar el ZIP. Intentá de nuevo.');
    } finally {
      btnDownload.disabled = false;
      btnLabel.textContent = 'Descargar .zip';
    }
  }

  // ── Steps ───────────────────────────────────────────────
  function updateSteps(active) {
    // active: 1, 2 o 3
    stepsBar.querySelectorAll('.step').forEach(el => {
      const n = parseInt(el.dataset.step);
      el.classList.remove('active', 'done');
      if (n < active)  el.classList.add('done');
      if (n === active) el.classList.add('active');
    });
  }

  // ── UI: mostrar/ocultar secciones ───────────────────────
  function showFilesUI() {
    cardSeed.style.display    = 'block';
    cardPreview.style.display = 'block';
    actionBar.style.display   = 'flex';
    fileCounter.style.display = 'block';
  }

  function hideFilesUI() {
    cardSeed.style.display    = 'none';
    cardPreview.style.display = 'none';
    actionBar.style.display   = 'none';
    fileCounter.style.display = 'none';
  }

  // ── Renderizar grid de preview ───────────────────────────
  function renderGrid() {
    previewGrid.innerHTML = '';

    const MAX_VISIBLE = 20; // mostramos hasta 20 thumbnails
    const visible = files.slice(0, MAX_VISIBLE);

    visible.forEach((file, i) => {
      const card = document.createElement('div');
      card.className = 'img-card';
      card.style.animationDelay = `${i * 0.04}s`;

      const newName = buildNewName(i);
      const num     = pad((parseInt(startInput.value) || 1) + i, digitsInput.value);

      // Thumbnail con FileReader
      const url = URL.createObjectURL(file);
      const img = document.createElement('img');
      img.className = 'img-thumb';
      img.alt = file.name;
      img.src = url;
      img.onload = () => URL.revokeObjectURL(url);
      img.onerror = () => {
        // Fallback placeholder
        img.replaceWith(makePlaceholder());
      };

      const badge = document.createElement('div');
      badge.className = 'img-badge';
      badge.textContent = num;

      const body = document.createElement('div');
      body.className = 'img-body';

      const oldDiv = document.createElement('div');
      oldDiv.className = 'img-old';
      oldDiv.title = file.name;
      oldDiv.textContent = file.name;

      const newDiv = document.createElement('div');
      newDiv.className = 'img-new';
      newDiv.title = newName;
      newDiv.textContent = newName;

      body.appendChild(oldDiv);
      body.appendChild(newDiv);
      card.appendChild(img);
      card.appendChild(badge);
      card.appendChild(body);
      const removeBtn = document.createElement('button');
      removeBtn.className = 'img-remove';
      removeBtn.title = 'Excluir imagen';
      removeBtn.textContent = '✕';
      removeBtn.addEventListener('click', () => removeFile(i));
      card.appendChild(removeBtn);

      card.draggable = true;
      card.dataset.index = i;

      card.addEventListener('dragstart', e => {
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', i);
        setTimeout(() => card.classList.add('dragging'), 0);
      });

      card.addEventListener('dragend', () => {
        card.classList.remove('dragging');
        document.querySelectorAll('.img-card').forEach(c => c.classList.remove('drag-over-card'));
      });

      card.addEventListener('dragover', e => {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        document.querySelectorAll('.img-card').forEach(c => c.classList.remove('drag-over-card'));
        card.classList.add('drag-over-card');
      });

      card.addEventListener('dragleave', e => {
        if (!card.contains(e.relatedTarget)) card.classList.remove('drag-over-card');
      });

      card.addEventListener('drop', e => {
        e.preventDefault();
        card.classList.remove('drag-over-card');
        const fromIndex = parseInt(e.dataTransfer.getData('text/plain'));
        const toIndex = parseInt(card.dataset.index);
        if (fromIndex === toIndex) return;

        // Intercambiar en el array
        const moved = files.splice(fromIndex, 1)[0];
        files.splice(toIndex, 0, moved);

        renderGrid();
        updatePreviewLabel();
        updateMeta();
      });

      previewGrid.appendChild(card);
    });

    // Pill de "y N más" si hay más de MAX_VISIBLE
    if (files.length > MAX_VISIBLE) {
      const more = document.createElement('div');
      more.style.cssText = `
        background: var(--surface2); border: 0.5px dashed var(--border2);
        border-radius: var(--radius-sm); display: flex; align-items: center;
        justify-content: center; min-height: 148px;
        color: var(--muted); font-size: 13px; font-family: var(--mono);
        cursor: default;
      `;
      more.textContent = `+${files.length - MAX_VISIBLE} más`;
      previewGrid.appendChild(more);
    }
  }

  function makePlaceholder() {
    const div = document.createElement('div');
    div.className = 'img-thumb-placeholder';
    div.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
      <rect x="3" y="3" width="18" height="18" rx="2"/>
      <circle cx="8.5" cy="8.5" r="1.5"/>
      <polyline points="21 15 16 10 5 21"/>
    </svg>`;
    return div;
  }

  // ── Actualizar nombres en la grilla sin re-renderizar ────
  function updateGridNames() {
    const cards    = previewGrid.querySelectorAll('.img-card');
    const start    = parseInt(startInput.value) || 1;
    const d        = digitsInput.value;
    const seed     = seedInput.value.trim() || 'imagen';

    cards.forEach((card, i) => {
      const num     = pad(start + i, d);
      const ext     = getExt(files[i]?.name || '');
      const newName = `${seed}_${num}${ext ? '.' + ext : ''}`;

      const badge  = card.querySelector('.img-badge');
      const newDiv = card.querySelector('.img-new');
      if (badge)  badge.textContent  = num;
      if (newDiv) { newDiv.textContent = newName; newDiv.title = newName; }
    });

    updatePreviewLabel();
    updateMeta();
  }

  function updateMeta() {
    const total  = files.length;
    previewMeta.textContent  = `${total} archivos`;
    countBubble.textContent  = `${total} ${total === 1 ? 'archivo' : 'archivos'}`;
    fileCounter.textContent  = `${total} / ${MAX}`;
  }

  // ── Agregar archivos ─────────────────────────────────────
  function addFiles(incoming) {
    const allowed = ['image/jpeg','image/png','image/webp','image/gif'];
    const valid   = Array.from(incoming).filter(f => allowed.includes(f.type));
    const invalid = Array.from(incoming).length - valid.length;

    if (invalid > 0) showError(`${invalid} archivo(s) ignorado(s) — solo se aceptan JPG, PNG, WEBP y GIF.`);

    const remaining = MAX - files.length;
    if (valid.length > remaining) {
      showError(`Límite de ${MAX} imágenes. Se agregaron ${remaining} de ${valid.length}.`);
    }

    const toAdd = valid.slice(0, remaining);
    if (toAdd.length === 0) return;

    files = [...files, ...toAdd];

    showFilesUI();
    renderGrid();
    updatePreviewLabel();
    updateMeta();
    updateSteps(2);
  }

  // ── Limpiar todo ─────────────────────────────────────────
  function clearAll() {
    files = [];
    previewGrid.innerHTML = '';
    fileInput.value = '';
    hideFilesUI();
    updateSteps(1);
  }

  function removeFile(index) {
    files.splice(index, 1);
    if (files.length === 0) {
      clearAll();
      return;
    }
    renderGrid();
    updatePreviewLabel();
    updateMeta();
  }

  // ── Descargar ZIP ────────────────────────────────────────
  async function downloadZip() {
    if (files.length === 0) return;

    btnDownload.disabled = true;

    try {
      const zip = new JSZip();

      for (let i = 0; i < files.length; i++) {
        const newName = buildNewName(i);
        zip.file(newName, files[i]);
        // Progreso al agregar archivos (primera mitad: 0% → 50%)
        const pct = Math.round(((i + 1) / files.length) * 50);
        btnLabel.textContent = `Procesando ${i + 1}/${files.length} — ${pct}%`;
        // Ceder el hilo para que el DOM se actualice
        if (i % 10 === 0) await new Promise(r => setTimeout(r, 0));
      }

      const blob = await zip.generateAsync(
        { type: 'blob', compression: 'STORE' },
        (meta) => {
          // Progreso al comprimir (segunda mitad: 50% → 100%)
          const pct = 50 + Math.round(meta.percent / 2);
          btnLabel.textContent = `Empaquetando — ${pct}%`;
        }
      );

      const seedName = (seedInput.value.trim() || 'imagenes').replace(/\s+/g, '_');
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = `${seedName}_renombradas.zip`;
      a.click();
      URL.revokeObjectURL(a.href);

      updateSteps(3);
      showToast(`✓ ${files.length} ${files.length === 1 ? 'imagen descargada' : 'imágenes descargadas'}`);
      setTimeout(clearAll, 1200);

    } catch (err) {
      console.error(err);
      showError('Ocurrió un error al generar el ZIP. Intentá de nuevo.');
    } finally {
      btnDownload.disabled = false;
      btnLabel.textContent = 'Descargar .zip';
    }
  }

  // ── Eventos: Dropzone ────────────────────────────────────
  dropzone.addEventListener('click', () => fileInput.click());
  dropzone.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') fileInput.click(); });

  dropzone.addEventListener('dragover',  e => { e.preventDefault(); dropzone.classList.add('drag-over'); });
  dropzone.addEventListener('dragleave', e => { if (!dropzone.contains(e.relatedTarget)) dropzone.classList.remove('drag-over'); });
  dropzone.addEventListener('drop', e => {
    e.preventDefault();
    dropzone.classList.remove('drag-over');
    addFiles(e.dataTransfer.files);
  });

  fileInput.addEventListener('change', () => {
    if (fileInput.files.length) addFiles(fileInput.files);
  });

  // ── Eventos: inputs de nombre ────────────────────────────
  seedInput.addEventListener('input', () => {
    const invalid = /[\/\\:*?"<>|]/.test(seedInput.value);
    const hint = document.getElementById('seedHint');
    seedInput.classList.toggle('invalid', invalid);
    hint.classList.toggle('show', invalid);
    if (!invalid) updateGridNames();
  });
  startInput.addEventListener('input',  updateGridNames);
  digitsInput.addEventListener('input', updateGridNames);

  // ── Eventos: botones ─────────────────────────────────────
  // ── Eventos: botones ─────────────────────────────────────
  document.getElementById('btnOpts').addEventListener('click', (e) => {
    e.stopPropagation();
    document.getElementById('downloadMenu').classList.toggle('open');
  });
  document.addEventListener('click', () => {
    document.getElementById('downloadMenu').classList.remove('open');
  });

  btnDownload.addEventListener('click', () => downloadZipWith(null));
  document.getElementById('btnWithCsv').addEventListener('click',  () => downloadZipWith('csv'));
  document.getElementById('btnWithJson').addEventListener('click', () => downloadZipWith('json'));
  btnClear.addEventListener('click', clearAll);
  loadHistory();

  // ── Tema claro/oscuro ────────────────────────────────────
  const themeToggle = document.getElementById('themeToggle');
  const savedTheme  = localStorage.getItem('renamr_theme');
  if (savedTheme === 'light') document.body.classList.add('light');

  themeToggle.addEventListener('click', () => {
    document.body.classList.toggle('light');
    const isLight = document.body.classList.contains('light');
    localStorage.setItem('renamr_theme', isLight ? 'light' : 'dark');
  });
</script>
